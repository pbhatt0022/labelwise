VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY
VITE_GEMINI_MODEL=gemini-2.5-flash-lite
# Vision model used for label image OCR. Defaults to gemini-2.5-flash (better at dense small text).
# VITE_GEMINI_VISION_MODEL=gemini-2.5-flash
VITE_TEXTRACT_ENDPOINT=http://127.0.0.1:8787/api/ocr/textract
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=us-east-1

# Optional: pre-filled demo account for judges or public demos
# Create this account in Supabase first, then set these values
# The "Try with demo account" button on the login screen only appears if both are set
VITE_DEMO_EMAIL=
VITE_DEMO_PASSWORD=
